# ==========================================
# i3wm Configuration
# https://i3wm.org/docs/userguide.html
# ==========================================

# --- Base Settings ---
set $mod Mod4
floating_modifier $mod
tiling_drag modifier titlebar
font pango:Open sans 11

hide_edge_borders smart
default_border pixel 2

client.focused          #343746 #343746 #F8F8F2 #343746 #343746
client.focused_inactive #343746 #343746 #F8F8F2 #21222C #21222C
client.unfocused        #343746 #343746 #F8F8F2 #21222C #21222C

# --- Autostart (Run Once) ---
exec --no-startup-id dex --autostart --environment i3
exec --no-startup-id xss-lock --transfer-sleep-lock -- lock --nofork
exec --no-startup-id xrandr --dpi 96
exec --no-startup-id redshift -O 2000
exec --no-startup-id /usr/lib/mate-polkit/polkit-mate-authentication-agent-1
exec --no-startup-id snixembed --fork
exec --no-startup-id safeeyes
exec --no-startup-id /usr/bin/gnome-keyring-daemon --start --components=pkcs11,secrets,ssh
exec --no-startup-id dbus-update-activation-environment --systemd DISPLAY XAUTHORITY
exec --no-startup-id picom --vsync --backend glx
exec --no-startup-id autotiling
exec --no-startup-id dunst
exec --no-startup-id greenclip daemon
exec --no-startup-id battery_listener

# --- Autostart (On Reload) ---
exec_always --no-startup-id feh --no-fehbg --bg-fill $HOME/Pictures/wallpapers/background.png
exec_always --no-startup-id $HOME/.config/polybar/launch.sh
exec_always --no-startup-id libinput-gestures-setup restart
exec_always --no-startup-id "killall -q i3wsr; i3wsr"

# --- Hardware & Media Controls ---
bindsym XF86AudioRaiseVolume exec --no-startup-id volume_control -s +5 -m 125 && volume_level
bindsym XF86AudioLowerVolume exec --no-startup-id volume_control -s -5 -m 125 && volume_level
bindsym XF86AudioMute        exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle && volume_mute
bindsym XF86AudioMicMute     exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle && microphone_mute

bindsym $mod+XF86AudioRaiseVolume exec --no-startup-id "killall -q redshift; redshift -O 2000"
bindsym $mod+XF86AudioLowerVolume exec --no-startup-id redshift -x

bindsym XF86MonBrightnessUp   exec --no-startup-id brightness_control -s +2 && brightness_level
bindsym XF86MonBrightnessDown exec --no-startup-id brightness_control -s -2 && brightness_level

bindsym XF86ScreenSaver    exec --no-startup-id xset dpms force off
bindsym XF86TouchpadToggle exec --no-startup-id touchpad_toggle

# --- Application Shortcuts ---
bindsym $mod+Return exec kitty --single-instance
bindsym $mod+w      exec --no-startup-id zen-browser
bindsym $mod+e      exec --no-startup-id thunar
bindsym $mod+c      exec --no-startup-id "rofi -show vscode-recent -modi vscode-recent -no-default-config -config ~/.config/rofi/main.rasi -theme-str 'prompt { enabled: false; }'"
bindsym $mod+t      exec --no-startup-id pomotroid

bindsym $mod+space  exec --no-startup-id rofi -show drun -no-default-config -config ~/.config/rofi/main.rasi
bindsym $mod+a      exec --no-startup-id rofi -show drun -no-default-config -config ~/.config/rofi/dmenu.rasi
bindsym $mod+d      exec --no-startup-id dmenu_run
bindsym ctrl+F3     exec --no-startup-id dmenu_run
bindsym $mod+v      exec --no-startup-id rofi -modi "clipboard:greenclip print" -show clipboard -run-command '{cmd}' -no-default-config -config ~/.config/rofi/main.rasi

bindsym XF86Calculator exec --no-startup-id qalculate-gtk
bindsym Print          exec --no-startup-id flameshot gui
bindsym Insert         exec --no-startup-id flameshot full -c
bindsym $mod+s         exec --no-startup-id rofi-screenshot

bindsym ctrl+F1 exec --no-startup-id i3-sensible-terminal
bindsym ctrl+F2 exec --no-startup-id kitty
bindsym ctrl+F4 exec --no-startup-id killall picom

# --- System Commands ---
bindsym $mod+q          kill
bindsym $mod+i          exec lock
bindsym $mod+x          exec --no-startup-id rofi-powermenu
bindsym $mod+Shift+z    exec --no-startup-id systemctl suspend
bindsym $mod+Shift+c    reload
bindsym $mod+Shift+r    restart
bindsym $mod+Shift+e    exec "i3-nagbar -t warning -m 'Exit i3?' -B 'Yes' 'i3-msg exit'"

# --- Window Management ---
bindsym $mod+h split h
bindsym $mod+f fullscreen toggle
bindsym $mod+Shift+space floating toggle
bindsym $mod+Mod1+space focus mode_toggle

bindsym $mod+j focus left
bindsym $mod+k focus down
bindsym $mod+l focus up
bindsym $mod+semicolon focus right
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right
bindsym $mod+Shift+semicolon move right
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

bindsym $mod+minus       scratchpad show
bindsym $mod+Shift+minus move scratchpad

# --- Workspaces & Outputs ---
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

bindsym $mod+Mod1+1 move container to workspace number $ws1
bindsym $mod+Mod1+2 move container to workspace number $ws2
bindsym $mod+Mod1+3 move container to workspace number $ws3
bindsym $mod+Mod1+4 move container to workspace number $ws4
bindsym $mod+Mod1+5 move container to workspace number $ws5
bindsym $mod+Mod1+6 move container to workspace number $ws6
bindsym $mod+Mod1+7 move container to workspace number $ws7
bindsym $mod+Mod1+8 move container to workspace number $ws8
bindsym $mod+Mod1+9 move container to workspace number $ws9
bindsym $mod+Mod1+0 move container to workspace number $ws10

bindsym $mod+b move workspace to output right
bindsym $mod+n exec xrandr --auto --output eDP-1 --mode 1920x1080 --right-of HDMI-1 && i3-msg restart &
bindsym $mod+m exec xrandr --auto --output HDMI-1 --off && i3-msg restart &

# --- Resize Mode ---
mode "resize" {
        bindsym j resize shrink width 10 px or 10 ppt
        bindsym k resize grow height 10 px or 10 ppt
        bindsym l resize shrink height 10 px or 10 ppt
        bindsym semicolon resize grow width 10 px or 10 ppt

        bindsym Left resize shrink width 10 px or 10 ppt
        bindsym Down resize grow height 10 px or 10 ppt
        bindsym Up resize shrink height 10 px or 10 ppt
        bindsym Right resize grow width 10 px or 10 ppt

        bindsym Return mode "default"
        bindsym Escape mode "default"
        bindsym $mod+r mode "default"
}
bindsym $mod+r mode "resize"

# --- Gaps & Layout ---
gaps inner 8
gaps outer 0
smart_gaps off

set $mode_gaps Gaps: (o) outer, (i) inner
set $mode_gaps_outer Outer Gaps: +|-|0 (local), Shift + +|-|0 (global)
set $mode_gaps_inner Inner Gaps: +|-|0 (local), Shift + +|-|0 (global)
bindsym $mod+g mode "$mode_gaps"

mode "$mode_gaps" {
        bindsym o      mode "$mode_gaps_outer"
        bindsym i      mode "$mode_gaps_inner"
        bindsym Return mode "default"
        bindsym Escape mode "default"
}
mode "$mode_gaps_inner" {
        bindsym plus  gaps inner current plus 5
        bindsym minus gaps inner current minus 5
        bindsym 0     gaps inner current set 0
        bindsym Shift+plus  gaps inner all plus 5
        bindsym Shift+minus gaps inner all minus 5
        bindsym Shift+0     gaps inner all set 0
        bindsym Return mode "default"
        bindsym Escape mode "default"
}
mode "$mode_gaps_outer" {
        bindsym plus  gaps outer current plus 5
        bindsym minus gaps outer current minus 5
        bindsym 0     gaps outer current set 0
        bindsym Shift+plus  gaps outer all plus 5
        bindsym Shift+minus gaps outer all minus 5
        bindsym Shift+0     gaps outer all set 0
        bindsym Return mode "default"
        bindsym Escape mode "default"
}

# --- Bar ---
bar {
        mode invisible
        tray_output none
}

# --- Window Rules ---
for_window [class="Qalculate-gtk"] floating enable, sticky enable
for_window [class="Firefox" title="Picture-in-Picture"] floating enable, sticky enable
for_window [class="mpv"] floating enable, resize set 800 450, move position center
for_window [class="Pomotroid"] floating enable, resize set 350 500, move position right
for_window [class="nmtui-float"] floating enable, resize set 600 400, move position center
